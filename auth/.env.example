# Artemis Auth Service — environment configuration
# Copy to .env and fill in values

ENVIRONMENT=development
LOG_LEVEL=info

DATABASE_URL=sqlite:///auth_dev.db

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/1

# RSA keys — leave blank in dev (auto-generated to keys/)
# In production, set these to the PEM strings
PRIVATE_KEY_PEM=
PUBLIC_KEY_PEM=

# Google OAuth — get from Google Cloud Console
GOOGLE_CLIENT_ID=

# Disable auth bypass (keep false in prod)
DISABLE_AUTH=false
