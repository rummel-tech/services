# Local development environment — Artemis running locally, all other services in staging.
# Copy to .env.local and fill in the staging ALB URLs before running docker-compose.local.yml.
#
# Get staging ALB DNS from:
#   aws elbv2 describe-load-balancers --names staging-alb --region us-east-1 \
#     --query 'LoadBalancers[0].DNSName' --output text

# Required: Anthropic API key for the AI agent
ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub token for platform dev tools (platform__list_issues, etc.)
GITHUB_TOKEN=

# Staging service URLs — replace <STAGING_ALB_DNS> with the actual ALB hostname
# Example: http://staging-alb-123456789.us-east-1.elb.amazonaws.com
STAGING_AUTH_URL=http://<STAGING_ALB_DNS>/auth
STAGING_WORKOUT_PLANNER_URL=http://<STAGING_ALB_DNS>/workout-planner
STAGING_MEAL_PLANNER_URL=http://<STAGING_ALB_DNS>/meal-planner
STAGING_HOME_MANAGER_URL=http://<STAGING_ALB_DNS>/home-manager
STAGING_VEHICLE_MANAGER_URL=http://<STAGING_ALB_DNS>/vehicle-manager
STAGING_WORK_PLANNER_URL=http://<STAGING_ALB_DNS>/work-planner
STAGING_EDUCATION_PLANNER_URL=http://<STAGING_ALB_DNS>/education-planner
STAGING_CONTENT_PLANNER_URL=http://<STAGING_ALB_DNS>/content-planner
