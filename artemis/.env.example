# Artemis Platform Service
ENVIRONMENT=development
LOG_LEVEL=info
PORT=8080

# Auth service URL
ARTEMIS_AUTH_URL=http://localhost:8090

# Module service URLs
WORKOUT_PLANNER_URL=http://localhost:8000
MEAL_PLANNER_URL=http://localhost:8010
HOME_MANAGER_URL=http://localhost:8020
VEHICLE_MANAGER_URL=http://localhost:8030
WORK_PLANNER_URL=http://localhost:8040
EDUCATION_PLANNER_URL=http://localhost:8050
CONTENT_PLANNER_URL=http://localhost:8060

# Module registry config (relative to CWD)
MODULES_CONFIG=config/modules.yaml

# Claude API key (required for AI agent)
ANTHROPIC_API_KEY=

# GitHub token (optional — enables platform dev tools)
GITHUB_TOKEN=

# Background refresh interval in seconds (0 to disable)
REGISTRY_REFRESH_SECONDS=300
