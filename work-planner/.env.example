# Work Planner Service Configuration
APP_NAME=work-planner
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
PORT=8040

# Database - SQLite for development, Postgres for production
DATABASE_URL=sqlite:///work_dev.db
# DATABASE_URL=postgresql://user:password@localhost:5432/work_planner

# Auth
JWT_SECRET=change-me-in-production-must-be-at-least-32-chars
DISABLE_AUTH=false

# Redis (optional in dev)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/4

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:8081"]
